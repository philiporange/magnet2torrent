# Example .env file for magnet2torrent

# Directory where output torrent files will be saved.
# Defaults to the current directory if not set.
# OUTPUT_DIR="./torrents"

# Proxy settings (optional)
# PROXY_HOST="your_proxy_host"
# PROXY_PORT="8080"
# PROXY_TYPE="socks5" # or "http", "socks4"
# PROXY_USER="your_proxy_user"
# PROXY_PASS="your_proxy_password"

# URL for the tracker list.
# Defaults to "https://raw.githubusercontent.com/ngosang/trackerslist/refs/heads/master/trackers_best.txt"
# TRACKER_LIST_URL="https://your.custom.trackerlist.com/trackers.txt"

# Directory for caching tracker lists and other temporary data.
# Defaults to "/tmp/magnet_to_rtorrent"
# CACHE_DIR="/var/cache/magnet2torrent"

# Time-to-live for cache entries in seconds.
# Defaults to 86400 seconds (24 hours).
# CACHE_TTL="3600" # 1 hour
